// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/prisma-accelerate-init

generator client {
  provider = "prisma-client-js"
}

// PostgreSQL required for Prisma enum support (SQLite connector does not support enums)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Zone {
  id        String   @id @default(uuid())
  zoneKey   String   @unique
  labelRu   String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Location {
  id       String @id @default(uuid())
  name     String
  address  String
  timezone String

  users          User[]
  services       Service[]
  packages       Package[]
  subscriptions  Subscription[]
  workingHours   WorkingHour[]
  appointments   Appointment[]
  exceptions     Exception[]   @relation("LocationExceptions")
  catalogItems   CatalogItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// UserState: "IDLE" | "CONSULTING" | "BOOKING_FLOW" | "BOOKED"
model User {
  id         String  @id @default(uuid())
  name       String
  email      String  @unique
  password   String
  role       String  @default("CLIENT")
  state      String  @default("IDLE")
  telegramId String? @unique

  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])

  photoUrl           String?
  publicTitleRu      String?
  isActive           Boolean @default(true)
  isVisibleOnWebsite Boolean @default(true)
  sortOrder          Int     @default(0)

  clientAppointments Appointment[]   @relation("ClientAppointments")
  masterAppointments Appointment[]   @relation("MasterAppointments")
  masterServices     MasterService[]
  masterPackages     MasterPackage[]
  workingHours       WorkingHour[]   @relation("MasterWorkingHours")

  exceptions Exception[] @relation("UserExceptions")
  bookings   Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
}

model Service {
  id          String  @id @default(uuid())
  name        String
  durationMin Int
  price       Int

  category    CatalogCategory?
  gender      CatalogGender?
  groupKey    String?
  /// Stable semantic zone identity (e.g. "armpits", "lower-legs"). Same zone across genders shares the same zoneKey.
  zoneKey     String?
  description String?
  /// Electro page 2nd column (display-only): session time label (e.g. "15 мин"). NOT used for booking.
  sessionDurationLabelRu String?
  /// Electro page 3rd column: "Кол-во сеансов / примечание" (e.g. "8–12 сеансов")
  sessionsNoteRu String?
  /// Electro page 4th column: approximate course duration (e.g. "6–9 месяцев")
  courseTermRu String?
  serviceKind   ServiceKind @default(BUSINESS)
  isVisible     Boolean @default(true)
  isBookable    Boolean @default(true)
  showOnWebsite Boolean @default(true)
  showInBot     Boolean @default(true)
  sortOrder     Int     @default(0)

  /// Migration linkage: set when Service was created from CatalogItem. Used for idempotent backfill only.
  sourceCatalogItemId String? @unique

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  packageLinks     PackageService[]
  appointmentLinks AppointmentService[]
  masterLinks      MasterService[]
  catalogItems     CatalogItem[]
  subscriptionsAsBase Subscription[] @relation("SubscriptionBaseService")
  bookings         Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@index([sourceCatalogItemId])
  @@index([zoneKey])
}

model MasterService {
  id        String @id @default(uuid())
  masterId  String
  serviceId String

  master  User    @relation(fields: [masterId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([masterId, serviceId])
  @@index([masterId])
  @@index([serviceId])
}

model Package {
  id    String @id @default(uuid())
  name  String
  price Int     @default(0)
  durationMin Int @default(0)

  category    CatalogCategory?
  gender      CatalogGender?
  description   String?
  isVisible     Boolean @default(true)
  isBookable    Boolean @default(true)
  showOnWebsite Boolean @default(true)
  showInBot     Boolean @default(false)
  sortOrder     Int     @default(0)

  /// Classification: MIGRATED = from migration scripts, MANUAL = admin-created.
  packageKind PackageKind @default(MIGRATED)

  /// Link to legacy CatalogItem (type PACKAGE). Null = legacy package (do not modify).
  sourceLegacyPackageId String?
  /// Variant key for normalized packages: "female" | "male" | "unisex" | null (single variant). Unique with sourceLegacyPackageId.
  normalizedVariantKey  String?

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  services       PackageService[]
  masterPackages MasterPackage[]
  subscriptionsAsBase Subscription[] @relation("SubscriptionBasePackage")
  bookings       Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sourceLegacyPackageId, normalizedVariantKey])
  @@index([locationId])
  @@index([sourceLegacyPackageId])
}

model PackageService {
  id        String   @id @default(uuid())
  packageId String
  serviceId String
  sortOrder Int      @default(0)

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([packageId, serviceId])
  @@index([packageId])
  @@index([serviceId])
}

model MasterPackage {
  id        String   @id @default(uuid())
  masterId  String
  packageId String

  master  User    @relation(fields: [masterId], references: [id], onDelete: Cascade)
  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([masterId, packageId])
  @@index([masterId])
  @@index([packageId])
}

model Subscription {
  id    String @id @default(uuid())
  name  String
  category CatalogCategory
  gender   CatalogGender?
  description String?
  baseServiceId String?
  basePackageId  String?
  quantity      Int     @default(1)
  discountPercent Int   @default(0)
  finalPrice    Int     @default(0)
  isVisible    Boolean @default(true)
  showOnWebsite Boolean @default(true)
  showInBot     Boolean @default(false)
  sortOrder     Int     @default(0)

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  baseService Service? @relation("SubscriptionBaseService", fields: [baseServiceId], references: [id])
  basePackage Package? @relation("SubscriptionBasePackage", fields: [basePackageId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@index([baseServiceId])
  @@index([basePackageId])
}

model Appointment {
  id String @id @default(uuid())

  clientId String
  client   User   @relation("ClientAppointments", fields: [clientId], references: [id])

  masterId String
  master   User   @relation("MasterAppointments", fields: [masterId], references: [id])

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  startAt DateTime
  endAt   DateTime

  status String @default("PENDING")

  services AppointmentService[]
  noShow   NoShow?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([masterId, startAt])
  @@index([clientId])
  @@index([locationId])
}

model AppointmentService {
  id String @id @default(uuid())

  appointmentId String
  serviceId     String

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  service     Service     @relation(fields: [serviceId], references: [id])

  @@unique([appointmentId, serviceId])
}

/// dayOfWeek: 1 = Monday, 7 = Sunday (ISO weekday)
/// When masterId is set, row is master-specific; when null, location-level default.
model WorkingHour {
  id String @id @default(uuid())

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  masterId String?
  master   User?   @relation("MasterWorkingHours", fields: [masterId], references: [id], onDelete: Cascade)

  dayOfWeek Int // 1-7 (Mon-Sun)

  /// Time of day, 24h format "HH:MM" (e.g. "09:00")
  startTime String
  /// Time of day, 24h format "HH:MM" (e.g. "18:00")
  endTime   String

  createdAt DateTime @default(now())

  @@index([locationId, dayOfWeek])
  @@index([masterId, dayOfWeek])
}

model Exception {
  id String @id @default(uuid())

  masterId String?
  master   User?   @relation("UserExceptions", fields: [masterId], references: [id])

  locationId String?
  location   Location? @relation("LocationExceptions", fields: [locationId], references: [id])

  date    DateTime  // start of blocked period (or single day for DAY_OFF)
  dateTo  DateTime? // end of blocked period (null = single day)
  startAt DateTime?
  endAt   DateTime?

  reason String?

  createdAt DateTime @default(now())

  @@index([date])
  @@index([masterId])
  @@index([locationId])
}

model NoShow {
  id String @id @default(uuid())

  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  createdAt DateTime @default(now())
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum BookingSource {
  BOT
  ADMIN
}

/// Telegram conversational flow state (IDLE | CONSULTING | BOOKING_FLOW | BOOKED). Keyed by telegramId; source of truth for bot state (Phase 4).
model TelegramSession {
  id         String   @id @default(uuid())
  telegramId String   @unique
  state      String   @default("IDLE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Customer {
  id               String   @id @default(uuid())
  name             String
  phone            String?  @unique
  telegramId       String?  @unique
  telegramUsername String?
  telegramFirstName String?
  telegramLastName  String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  bookings Booking[]

  @@index([phone])
  @@index([telegramId])
}

model Booking {
  id          String        @id @default(uuid())
  userId      String?
  user        User?         @relation(fields: [userId], references: [id])
  customerId  String?
  customer    Customer?     @relation(fields: [customerId], references: [id])
  source      BookingSource?
  serviceId   String?
  packageId   String?
  masterId    String?
  locationId  String?
  scheduledAt DateTime?
  status      BookingStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  confirmedAt DateTime?
  cancelledAt DateTime?
  completedAt DateTime?
  expiresAt   DateTime?

  reminder10hSentAt DateTime?
  reminder2hSentAt  DateTime?

  service Service? @relation(fields: [serviceId], references: [id])
  package Package? @relation(fields: [packageId], references: [id])

  @@index([userId])
  @@index([customerId])
  @@index([status])
  @@index([scheduledAt])
  @@index([expiresAt])
  @@index([serviceId])
  @@index([packageId])
}

enum ServiceKind {
  BUSINESS
  LEGACY_TEMPLATE
}

enum PackageKind {
  MIGRATED
  MANUAL
}

enum CatalogCategory {
  LASER
  WAX
  ELECTRO
  MASSAGE
}

enum CatalogItemType {
  ZONE
  OFFER
  INFO
  PACKAGE
}

enum CatalogGender {
  FEMALE
  MALE
  UNISEX
}

model CatalogItem {
  id String @id @default(uuid())

  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  category CatalogCategory
  type     CatalogItemType
  gender   CatalogGender?
  groupKey String?

  titleRu       String
  subtitleRu    String?
  descriptionRu String?
  sessionsNoteRu String?

  price       Int?
  durationMin Int?

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  isVisible Boolean @default(true)
  sortOrder Int     @default(0)

  packageItemsAsPackage CatalogItemPackage[] @relation("PackageItems")
  packageItemsAsChild   CatalogItemPackage[] @relation("PackageChild")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@index([locationId, category, isVisible, sortOrder])
  @@index([locationId, category, groupKey, isVisible, sortOrder])
  @@index([serviceId])
}

model CatalogItemPackage {
  id        String @id @default(uuid())
  packageId String
  itemId    String
  sortOrder Int    @default(0)

  package CatalogItem @relation("PackageItems", fields: [packageId], references: [id], onDelete: Cascade)
  item    CatalogItem @relation("PackageChild", fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([packageId, itemId])
  @@index([packageId])
  @@index([itemId])
}
